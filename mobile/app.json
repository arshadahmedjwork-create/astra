{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.astradairy.mobile",
      "buildNumber": "6",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Astra Dairy needs your location to deliver fresh milk to your doorstep.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Astra Dairy needs background location to track your delivery in real-time.",
        "NSLocationAlwaysUsageDescription": "Astra Dairy needs background location to track your delivery in real-time.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.astradairy.mobile",
      "versionCode": 6,
      "targetSdkVersion": 36,
      "compileSdkVersion": 36,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "01000d55-1e16-4d0d-be8c-4eafab5964bb"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/01000d55-1e16-4d0d-be8c-4eafab5964bb"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.21",
            "newArchEnabled": true
          }
        }
      ]
    ],
    "owner": "arshd_ahmed"
  }
}
